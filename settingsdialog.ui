QLabel { color: #bbb; }
QComboBox { background-color: #252525; border: 1px solid #444; color: white; padding: 5px; border-radius: 4px; }
QCheckBox { color: #ddd; spacing: 8px; font-size: 11pt; font-weight: bold; }
QCheckBox::indicator { width: 20px; height: 20px; }
QPushButton { background-color: #333; color: white; border: 1px solid #444; padding: 10px 30px; border-radius: 4px; font-weight: bold; }
QPushButton:hover { background-color: #444; border-color: #55aaff; }
QPushButton#saveButton { background-color: #0055ff; border: none; }
